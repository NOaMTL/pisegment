# ==========================================
# Configuration API Externe (CRON)
# ==========================================
# Variables pour CronApiService (app/Services/ExternalApi/CronApiService.php)

# URL de base de l'API externe
EXTERNAL_API_BASE_URI=https://api.external.com

# Credentials OAuth (client_credentials)
EXTERNAL_API_CLIENT_ID=your_client_id_here
EXTERNAL_API_CLIENT_SECRET=your_client_secret_here

# Proxy (optionnel) - Laissez vide si pas de proxy
# Format: http://proxy.company.com:8080
# Avec auth: http://user:password@proxy.company.com:8080
EXTERNAL_API_PROXY=

# ==========================================
# Notes:
# ==========================================
# - Le token est automatiquement récupéré et mis en cache
# - Pas de refresh token : authentification complète à chaque expiration
# - Le proxy peut être lent : 5 tentatives avec timeouts de 90s configurés
# - Token valide pendant 55 minutes (cache Laravel)
