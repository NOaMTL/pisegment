# Configuration du service HTTP Client (Guzzle)
# Pour utiliser avec App\Services\Http\HttpClientInterface

# API Externe - URL de base
API_BASE_URI=https://api.example.com

# API Externe - OAuth Credentials
API_CLIENT_ID=your_client_id_here
API_CLIENT_SECRET=your_client_secret_here

# API Externe - Proxy (optionnel)
# Format avec authentification: http://username:password@proxy.company.com:8080
# Format sans authentification: http://proxy.company.com:8080
# Commentez ou laissez vide si pas de proxy
API_PROXY=http://proxy.company.com:8080

# API Externe - Timeouts (en secondes)
API_TIMEOUT=30
API_CONNECT_TIMEOUT=10

# API Externe - Nombre de retries
API_MAX_RETRIES=1

# ===================================
# Configuration pour plusieurs APIs
# ===================================

# CRM API
CRM_API_BASE_URI=https://crm.example.com
CRM_API_CLIENT_ID=crm_client_id
CRM_API_CLIENT_SECRET=crm_client_secret
CRM_API_PROXY=

# Payment API
PAYMENT_API_BASE_URI=https://payment.example.com
PAYMENT_API_KEY=payment_api_key

# Analytics API
ANALYTICS_API_BASE_URI=https://analytics.example.com
ANALYTICS_API_TOKEN=analytics_token

# ===================================
# Exemple d'utilisation
# ===================================

# 1. Pour développement local (sans proxy):
# API_BASE_URI=https://api-dev.example.com
# API_CLIENT_ID=dev_client_id
# API_CLIENT_SECRET=dev_secret
# API_PROXY=

# 2. Pour production avec proxy d'entreprise:
# API_BASE_URI=https://api.example.com
# API_CLIENT_ID=prod_client_id
# API_CLIENT_SECRET=prod_secret
# API_PROXY=http://proxy.company.com:8080

# 3. Pour staging avec proxy authentifié:
# API_BASE_URI=https://api-staging.example.com
# API_CLIENT_ID=staging_client_id
# API_CLIENT_SECRET=staging_secret
# API_PROXY=http://user:pass@proxy.company.com:8080
